# DATABASE_URL is required for storing Tariffs and Admin settings. For Vercel, you can use Neon Postgres or Supabase.
DATABASE_URL="postgresql://thai_energy:thai_energy_password@localhost:5432/thai_energy_planner?schema=public"
NEXT_PUBLIC_APP_NAME="Thai Energy Planner"
PORT=3000
NODE_ENV="development"
# Required to access /admin routes. Keep this secret in your hosting provider (e.g. Vercel Environment Variables).
# You can generate one using: `openssl rand -base64 32`
ADMIN_ACCESS_TOKEN="replace-with-a-long-random-token"
