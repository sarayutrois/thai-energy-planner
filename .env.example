# DATABASE_URL is required for storing Tariffs and Admin settings. For Vercel, you can use Neon Postgres or Supabase.
DATABASE_URL="postgresql://thai_energy:thai_energy_password@localhost:5432/thai_energy_planner?schema=public"
DIRECT_URL="postgresql://thai_energy:thai_energy_password@localhost:5432/thai_energy_planner?schema=public"
# Optional Supabase Auth server validation. Once configured, use these to require
# authenticated users before persisting user-owned data.
# NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
# Configure a shared rate limiter/WAF in production when running multiple instances.
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""
NEXT_PUBLIC_APP_NAME="Thai Energy Planner"
PORT=3000
NODE_ENV="development"
# Required to access /admin routes. Keep this secret in your hosting provider (e.g. Vercel Environment Variables).
# You can generate one using: `openssl rand -base64 32`
ADMIN_ACCESS_TOKEN="replace-with-a-long-random-token"
